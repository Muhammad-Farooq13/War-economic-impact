# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=war_economic_impact

# ── Paths (override config.yaml defaults if needed) ───────────────────────────
RAW_DATA_PATH=data/raw/war_economic_impact_dataset.csv
MODEL_SAVE_DIR=models/

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_THEME=dark
