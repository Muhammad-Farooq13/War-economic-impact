# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# ── Environments ──────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
.conda/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data (keep raw versioned; processed is reproducible) ──────────────────────
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep
# Uncomment below if raw data is large / proprietary
# data/raw/

# ── Model Artefacts ───────────────────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.model
!models/regression_xgb.joblib
!models/classification_xgb.joblib
!models/scaler_xgb.joblib
mlruns/

# ── Reports & Logs ────────────────────────────────────────────────────────────
reports/figures/*.png
reports/figures/*.html
reports/*.log
*.log

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ── Editor & OS ───────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Types ─────────────────────────────────────────────────────────────────────
.mypy_cache/
